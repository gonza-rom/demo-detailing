---
// src/pages/index.astro
const TURNOS_URL = "http://localhost:3000/reservar/jlm-detailing";

const servicios = [
  {
    id: "basico",
    nombre: "Lavado Básico",
    precio: "$8.000",
    duracion: "1 hora",
    descripcion: "Limpieza exterior e interior completa.",
    items: ["Lavado exterior a mano", "Aspirado interior", "Limpieza de vidrios", "Aromatización"],
    color: "#60a5fa",
  },
  {
    id: "pro",
    nombre: "Detailing Pro",
    precio: "$18.000",
    duracion: "3 horas",
    descripcion: "Restauración profunda de pintura y tapizado.",
    items: ["Todo lo del Básico" , "Pulido de pintura", "Limpieza de llantas", "Tratamiento de plásticos", "Encerado protector"],
    color: "#a78bfa",
    destacado: true,
  },
  {
    id: "premium",
    nombre: "Detailing Premium",
    precio: "$35.000",
    duracion: "6 horas",
    descripcion: "Protección cerámica de larga duración.",
    items: ["Todo lo del Pro", "Aplicación de cerámica", "Descontaminación de pintura", "Ozono interior", "Garantía 6 meses"],
    color: "#fbbf24",
  },
];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="JLM Detailing — Servicio profesional de lavado y detailing automotriz en Catamarca. Reservá tu turno online." />
  <title>JLM Detailing — Catamarca</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&display=swap" rel="stylesheet" />
</head>

<body>

<!-- ══ NAV ══════════════════════════════════════════════════ -->
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-jlm">JLM</span>
      <span class="logo-det">DETAILING</span>
    </a>
    <div class="nav-links">
      <a href="#servicios">Servicios</a>
      <a href="#galeria">Galería</a>
      <a href="#contacto">Contacto</a>
      <a href={TURNOS_URL} class="nav-cta">Reservar turno</a>
    </div>
  </div>
</nav>

<!-- ══ HERO ═════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-glow-1"></div>
    <div class="hero-glow-2"></div>
  </div>

  <div class="hero-content">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Catamarca · Argentina
    </div>

    <h1 class="hero-title">
      TU AUTO<br />
      <em>MERECE</em><br />
      LO MEJOR
    </h1>

    <p class="hero-sub">
      Servicio profesional de lavado y detailing automotriz.<br />
      Resultados que hablan por sí solos.
    </p>

    <div class="hero-actions">
      <a href={TURNOS_URL} class="btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Reservar turno ahora
      </a>
      <a href="#servicios" class="btn-ghost">Ver servicios</a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">500+</span>
        <span class="stat-label">Autos detallados</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">5★</span>
        <span class="stat-label">Calificación</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">3+</span>
        <span class="stat-label">Años de experiencia</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span>scroll</span>
  </div>
</section>

<!-- ══ SERVICIOS ════════════════════════════════════════════ -->
<section id="servicios" class="servicios">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Nuestros servicios</span>
      <h2 class="section-title">ELEGÍ TU<br /><em>TRATAMIENTO</em></h2>
      <p class="section-desc">Cada servicio está pensado para devolverle a tu auto el brillo que merece.</p>
    </div>

    <div class="servicios-grid">
      {servicios.map((s) => (
        <div class={`servicio-card ${s.destacado ? "destacado" : ""}`} style={`--card-color: ${s.color}`}>
          {s.destacado && <div class="card-badge">MÁS POPULAR</div>}
          <div class="card-header">
            <h3 class="card-nombre">{s.nombre}</h3>
            <div class="card-meta">
              <span class="card-duracion">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                {s.duracion}
              </span>
            </div>
          </div>
          <p class="card-desc">{s.descripcion}</p>
          <ul class="card-items">
            {s.items.map((item) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <div class="card-footer">
            <span class="card-precio">{s.precio}</span>
            <a href={`${TURNOS_URL}?servicio=${s.id}`} class="card-cta">Reservar</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ POR QUÉ NOSOTROS ══════════════════════════════════════ -->
<section class="porque">
  <div class="container">
    <div class="porque-grid">
      <div class="porque-text">
        <span class="section-tag">¿Por qué JLM?</span>
        <h2 class="section-title">CALIDAD QUE<br /><em>SE VE</em></h2>
        <p class="porque-desc">
          Usamos productos de primera línea y técnicas profesionales para garantizar resultados que duran.
          Tu auto es una inversión — la tratamos como tal.
        </p>
        <div class="porque-features">
          <div class="feature">
            <div class="feature-icon">⚡</div>
            <div>
              <p class="feature-title">Productos premium</p>
              <p class="feature-desc">Solo usamos productos certificados de marcas líderes.</p>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">🛡️</div>
            <div>
              <p class="feature-title">Garantía en cada trabajo</p>
              <p class="feature-desc">Si no quedás conforme, lo volvemos a hacer sin costo.</p>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">📍</div>
            <div>
              <p class="feature-title">Atención personalizada</p>
              <p class="feature-desc">Cada auto recibe el tratamiento específico que necesita.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="porque-visual">
        <div class="visual-card">
          <div class="visual-num">01</div>
          <p class="visual-text">Reservás tu turno online en segundos</p>
        </div>
        <div class="visual-card">
          <div class="visual-num">02</div>
          <p class="visual-text">Llevás tu auto al taller en el horario elegido</p>
        </div>
        <div class="visual-card">
          <div class="visual-num">03</div>
          <p class="visual-text">Te lo entregamos impecable, como nuevo</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ GALERÍA ═══════════════════════════════════════════════ -->
<section id="galeria" class="galeria">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Nuestros trabajos</span>
      <h2 class="section-title">RESULTADOS<br /><em>REALES</em></h2>
    </div>
    <div class="galeria-grid">
      <div class="galeria-item tall">
        <div class="galeria-placeholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <span>Foto trabajo 1</span>
        </div>
      </div>
      <div class="galeria-item">
        <div class="galeria-placeholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <span>Foto trabajo 2</span>
        </div>
      </div>
      <div class="galeria-item">
        <div class="galeria-placeholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <span>Foto trabajo 3</span>
        </div>
      </div>
      <div class="galeria-item wide">
        <div class="galeria-placeholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <span>Foto trabajo 4</span>
        </div>
      </div>
    </div>
    <div class="galeria-ig">
      <a href="https://www.instagram.com/jlmdetailing_/" target="_blank" rel="noopener noreferrer" class="ig-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        Ver más en Instagram @jlmdetailing_
      </a>
    </div>
  </div>
</section>

<!-- ══ CTA CENTRAL ═══════════════════════════════════════════ -->
<section class="cta-section">
  <div class="cta-bg">
    <div class="cta-glow"></div>
  </div>
  <div class="container cta-inner">
    <h2 class="cta-title">¿LISTO PARA<br /><em>EL CAMBIO?</em></h2>
    <p class="cta-desc">Reservá tu turno ahora y dale a tu auto el tratamiento que merece.</p>
    <a href={TURNOS_URL} class="btn-primary btn-xl">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      Reservar turno online
    </a>
    <p class="cta-sub">Sin registro · Confirmación inmediata</p>
  </div>
</section>

<!-- ══ CONTACTO ══════════════════════════════════════════════ -->
<section id="contacto" class="contacto">
  <div class="container">
    <div class="contacto-grid">
      <div>
        <span class="section-tag">Contacto</span>
        <h2 class="section-title" style="font-size: clamp(2rem, 5vw, 3.5rem)">ENCONTRANOS</h2>
        <div class="contacto-items">
          <div class="contacto-item">
            <div class="contacto-icon">📍</div>
            <div>
              <p class="contacto-label">Ubicación</p>
              <p class="contacto-val">Catamarca, Argentina</p>
            </div>
          </div>
          <div class="contacto-item">
            <div class="contacto-icon">📱</div>
            <div>
              <p class="contacto-label">WhatsApp</p>
              <a href="https://wa.me/543834000000" class="contacto-val contacto-link">+54 383 400-0000</a>
            </div>
          </div>
          <div class="contacto-item">
            <div class="contacto-icon">📷</div>
            <div>
              <p class="contacto-label">Instagram</p>
              <a href="https://www.instagram.com/jlmdetailing_/" target="_blank" class="contacto-val contacto-link">@jlmdetailing_</a>
            </div>
          </div>
        </div>
      </div>
      <div class="contacto-cta-box">
        <p class="box-tag">¿Tenés dudas?</p>
        <p class="box-text">Escribinos por WhatsApp y te respondemos en minutos.</p>
        <a href="https://wa.me/543834000000?text=Hola!%20Quiero%20consultar%20sobre%20el%20detailing" target="_blank" class="btn-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.856L.054 23.285a.75.75 0 0 0 .921.921l5.43-1.478A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.693-.503-5.235-1.382l-.374-.217-3.876 1.054 1.054-3.876-.217-.374A9.953 9.953 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ══ FOOTER ════════════════════════════════════════════════ -->
<footer>
  <div class="container footer-inner">
    <a href="/" class="nav-logo">
      <span class="logo-jlm">JLM</span>
      <span class="logo-det">DETAILING</span>
    </a>
    <p class="footer-text">© 2026 JLM Detailing · Catamarca, Argentina</p>
    <p class="footer-powered">
      Turnos con <a href="https://devhub.com.ar" target="_blank">DevHub Turnos</a>
    </p>
  </div>
</footer>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black:   #080808;
    --black-2: #0e0e0e;
    --black-3: #151515;
    --black-4: #1c1c1c;
    --white:   #f5f5f0;
    --white-2: #a8a89e;
    --white-3: #5a5a54;
    --gold:    #dc2626;
    --gold-2:  #ef4444;
    --accent:  #e8e0d0;
    --font-display: 'Bebas Neue', sans-serif;
    --font-body:    'Barlow', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    backdrop-filter: blur(12px);
    background: rgba(8,8,8,0.85);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo { display: flex; align-items: baseline; gap: 6px; text-decoration: none; }
  .logo-jlm {
    font-family: var(--font-display);
    font-size: 1.5rem; letter-spacing: 0.05em;
    color: var(--gold-2);
  }
  .logo-det {
    font-family: var(--font-display);
    font-size: 1rem; letter-spacing: 0.15em;
    color: var(--white-2);
  }
  .nav-links { display: flex; align-items: center; gap: 2rem; }
  .nav-links a {
    font-size: 0.8125rem; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--white-2);
    text-decoration: none; transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-cta {
    background: var(--gold) !important;
    color: var(--black) !important;
    padding: 8px 18px !important;
    border-radius: 6px !important;
    font-weight: 600 !important;
    transition: background 0.2s, transform 0.2s !important;
  }
  .nav-cta:hover { background: var(--gold-2) !important; transform: translateY(-1px); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    padding: 8rem 2rem 4rem;
  }
  .hero-bg {
    position: absolute; inset: 0; z-index: 0;
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }
  .hero-glow-1 {
    position: absolute; top: 20%; left: 60%;
    width: 500px; height: 500px; border-radius: 50%;
    background: radial-gradient(circle, rgba(220,38,38,0.12) 0%, transparent 70%);
    filter: blur(60px);
  }
  .hero-glow-2 {
    position: absolute; bottom: 10%; left: 20%;
    width: 300px; height: 300px; border-radius: 50%;
    background: radial-gradient(circle, rgba(96,165,250,0.07) 0%, transparent 70%);
    filter: blur(60px);
  }
  .hero-content {
    position: relative; z-index: 1;
    max-width: 800px; width: 100%;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--gold);
    border: 1px solid rgba(220,38,38,0.3);
    padding: 6px 14px; border-radius: 99px;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease both;
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold);
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: var(--white);
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.6s 0.1s ease both;
  }
  .hero-title em {
    font-style: normal;
    -webkit-text-stroke: 2px var(--gold);
    color: transparent;
  }
  .hero-sub {
    font-size: 1.0625rem; color: var(--white-2);
    max-width: 480px; line-height: 1.7;
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.6s 0.2s ease both;
  }
  .hero-actions {
    display: flex; gap: 1rem; flex-wrap: wrap;
    margin-bottom: 4rem;
    animation: fadeInUp 0.6s 0.3s ease both;
  }
  .hero-stats {
    display: flex; align-items: center; gap: 2rem;
    animation: fadeInUp 0.6s 0.4s ease both;
  }
  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem; letter-spacing: 0.02em;
    color: var(--white);
  }
  .stat-label {
    display: block;
    font-size: 0.6875rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--white-3);
  }
  .stat-div {
    width: 1px; height: 40px;
    background: rgba(255,255,255,0.1);
  }
  .hero-scroll {
    position: absolute; bottom: 2rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    z-index: 1;
  }
  .scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollLine 2s ease infinite;
  }
  @keyframes scrollLine { 0%{transform:scaleY(0);transform-origin:top} 50%{transform:scaleY(1);transform-origin:top} 51%{transform-origin:bottom} 100%{transform:scaleY(0);transform-origin:bottom} }
  .hero-scroll span {
    font-size: 0.625rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--white-3);
    writing-mode: vertical-rl;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── BOTONES ── */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 28px; border-radius: 8px;
    background: var(--gold);
    color: var(--black);
    font-size: 0.9375rem; font-weight: 700;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover {
    background: var(--gold-2);
    transform: translateY(-2px);
